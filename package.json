{
  "name": "tripgem-root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd TripGem && next dev",
    "build": "cd TripGem && next build",
    "vercel-build": "cd TripGem && next build && cp -r .next ../ && cp -r public ../",
    "start": "cd TripGem && next start",
    "lint": "cd TripGem && eslint src/ --ext .ts,.tsx",
    "typecheck": "cd TripGem && tsc --noEmit",
    "test": "cd TripGem && vitest run",
    "test:watch": "cd TripGem && vitest",
    "analyze": "cd TripGem && ANALYZE=true next build",
    "generate-scores": "cd TripGem && node scripts/generate-harm-scores.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@sanity/vision": "^5.25.1",
    "@sentry/nextjs": "^10.53.1",
    "@serwist/next": "^9.5.11",
    "@serwist/sw": "^9.5.11",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.6.1",
    "@vercel/kv": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.17",
    "framer-motion": "^12.40.0",
    "fuzzysort": "^3.1.0",
    "lru-cache": "^11.5.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-sanity": "^12.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sanity": "^5.25.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
